    <fileDesc>
      <titleStmt>
        <title>Test IATE export</title>
      </titleStmt>
      <sourceDesc>
        <p>Export produced on 2019-06-30 for testing purposes.</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
  <text>
    <body>
      <termEntry id="IATE-1001">
        <descrip type="subjectField">LAW</descrip>
        <langSet xml:lang="nl">
          <tig>
            <term>bouwwerk</term>
